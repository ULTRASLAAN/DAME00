{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-java",
      "type": "shell",
      "command": "javac",
      "args": [
        "app/*.java",
        "vue/*.java",
        "modele/*.java"
      ],
      "group": "build",
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "run-java",
      "type": "shell",
      "command": "java",
      "args": [
        "app.Main"
      ],
      "dependsOn": "build-java"
    },
    {
      "label": "clean-java",
      "type": "shell",
      "command": "Get-ChildItem -Recurse -File -Filter *.class | Remove-Item -Force",
      "problemMatcher": []
    }
  ]
}
